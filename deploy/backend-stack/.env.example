CORE_API_IMAGE=ghcr.io/your-org/safeway-core:latest
FINANCIAL_API_IMAGE=ghcr.io/your-org/safeway-financial:latest

CORE_DB_URL=jdbc:mysql://10.0.3.87:3306/safeway_core
CORE_DB_USER=safeway
CORE_DB_PASSWORD=change-me

FINANCIAL_DB_URL=jdbc:mysql://10.0.3.87:3307/safeway_financial
FINANCIAL_DB_USER=safeway
FINANCIAL_DB_PASSWORD=change-me

RABBITMQ_HOST=10.0.2.xx
RABBITMQ_USER=safeway
RABBITMQ_PASSWORD=change-me
RABBITMQ_VHOST=/

AUTH_SERVICE_CLIENT_ID=safeway-core
AUTH_SERVICE_CLIENT_SECRET=change-me
AUTH_SERVICE_BASE_URL=http://core-api:8080
AUTH_SERVICE_TOKEN_ENDPOINT=/auth/v2/token/service

GOOGLE_PROJECTID=change-me
GOOGLE_MAPS_API_KEY=change-me
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-credentials.json
